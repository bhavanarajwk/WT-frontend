# Copy to `.env.local` and adjust for your environment.

# Leave empty in production so the browser calls same-origin /api/v1/* (Next.js BFF).
# For direct local API access without the BFF, set http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=

# Server-side upstream API for server-side BFF routes (google callback, refresh, proxy).
API_BASE_URL=http://localhost:8080

# Public frontend origin used for OAuth redirect URIs in production.
APP_URL=https://webtrak.webknot-dev.in

# Session policy (display + client timers; must match backend SESSION_* values).
NEXT_PUBLIC_SESSION_INACTIVITY_MINUTES=30
NEXT_PUBLIC_SESSION_MAX_HOURS=8

# Google OAuth client id (public). Used by /api/v1/google-signin on the frontend host.
GOOGLE_CLIENT_ID=
